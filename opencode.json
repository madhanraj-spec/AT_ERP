{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "nvidia": {
      "api": "openai",
      "name": "NVIDIA",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}"
      },
      "models": {
        "z-ai/glm-5.1": {
          "id": "z-ai/glm-5.1",
          "name": "GLM 5.1",
          "family": "glm",
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": {
            "context": 16384,
            "output": 16384
          }
        }
      }
    }
  },
  "model": "nvidia/z-ai/glm-5.1"
}
