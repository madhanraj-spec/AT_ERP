      if (alertInfo.type === 'late') hasLate = true;
      if (alertInfo.type === 'expected_today') hasExpectedToday = true;
    }

    if (dof.status === 'pending') hasPending = true;
    else if (dof.status === 'rejected') hasRejected = true;
    else if (dof.status === 'received') hasReceived = true;
