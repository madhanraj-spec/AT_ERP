          {/* Reset Filters button */}
          <div style={{ gridColumn: '1 / -1', display: 'flex', justifyContent: 'flex-end', marginTop: '0.5rem' }}>
            <button
              onClick={() => {
                setSearchOrderNumber('');
                setSearchMerchandiser('');
                setSearchBuyer('');
                setSearchVendor('');
                setSearchSeason('');
